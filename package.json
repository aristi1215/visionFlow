{
  "name": "ondeckai",
  "version": "1.0.0",
  "private": true,
  "description": "OndeckAI monorepo",
  "workspaces": [
    "frontend",
    "packages/*",
    "backend/packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ondeckai/api & npm run dev -w frontend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:api": "npm run dev -w @ondeckai/api",
    "build": "npm run build -w @ondeckai/shared && npm run build -w @ondeckai/api && npm run build -w frontend",
    "build:shared": "npm run build -w @ondeckai/shared",
    "build:api": "npm run build -w @ondeckai/api",
    "build:frontend": "npm run build -w frontend"
  },  
  "engines": {
    "node": ">=20"
  },
  "license": "ISC"
}
